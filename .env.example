# SkillOpt API Configuration
# Copy this file to SkillOpt/.env and fill in your key

# DeepSeek API (OpenAI-compatible)
AZURE_OPENAI_ENDPOINT=https://api.deepseek.com/v1
AZURE_OPENAI_API_KEY=sk-your-key-here
AZURE_OPENAI_AUTH_MODE=openai_compatible

# Alternative: Direct OpenAI
# AZURE_OPENAI_ENDPOINT=https://api.openai.com/v1
# AZURE_OPENAI_API_KEY=sk-xxx
# AZURE_OPENAI_AUTH_MODE=openai_compatible

# Alternative: Azure OpenAI
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-key
# AZURE_OPENAI_API_VERSION=2024-12-01-preview
